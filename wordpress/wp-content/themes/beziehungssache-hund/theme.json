{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "name": "Dunkelgruen",
          "slug": "forest",
          "color": "#263D35"
        },
        {
          "name": "Salbeigruen",
          "slug": "sage",
          "color": "#8FA394"
        },
        {
          "name": "Warmes Beige",
          "slug": "sand",
          "color": "#EDE5D8"
        },
        {
          "name": "Cremeweiss",
          "slug": "cream",
          "color": "#FAF8F3"
        },
        {
          "name": "Terrakotta",
          "slug": "terracotta",
          "color": "#B8674B"
        },
        {
          "name": "Anthrazit",
          "slug": "charcoal",
          "color": "#292B2A"
        },
        {
          "name": "Hellgrau",
          "slug": "mist",
          "color": "#ECEDE9"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": true,
      "units": [
        "px",
        "rem",
        "%",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Lora\", Georgia, serif",
          "name": "Display Serif",
          "slug": "display-serif"
        },
        {
          "fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "Body Sans",
          "slug": "body-sans"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.95rem",
          "name": "S"
        },
        {
          "slug": "medium",
          "size": "1.125rem",
          "name": "M"
        },
        {
          "slug": "large",
          "size": "1.5rem",
          "name": "L"
        },
        {
          "slug": "x-large",
          "size": "clamp(2.25rem, 5vw, 4.5rem)",
          "name": "XL"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--cream)",
      "text": "var(--wp--preset--color--charcoal)"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--terracotta)",
          "text": "var(--wp--preset--color--cream)"
        },
        "spacing": {
          "padding": {
            "top": "0.85rem",
            "bottom": "0.85rem",
            "left": "1.35rem",
            "right": "1.35rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body-sans)",
          "fontSize": "1rem",
          "fontWeight": "600"
        }
      },
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--forest)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "fontWeight": "600",
          "lineHeight": "1.15"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--forest)"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body-sans)",
      "fontSize": "1rem",
      "lineHeight": "1.65"
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "0.95rem",
          "fontWeight": "600"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "clamp(2.1rem, 4vw, 3.4rem)"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display-serif)",
          "fontSize": "1.5rem"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
